<% for(let i in pkgs) {
    let package = pkgs[i];
    let newBullet = "  " + bullet;
-%>
<%= bullet %> [<%= package.name %>](package-<%= package.prefix.replace(/\//g,'-') %>)
<% if(package.hasOwnProperty('subpackages')) { -%>
<%- partial('./templates/App/_packageTree.emd', {pkgs: package.subpackages, bullet: newBullet}) -%>
<% } } -%>
